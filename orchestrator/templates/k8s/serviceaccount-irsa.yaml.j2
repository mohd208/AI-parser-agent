apiVersion: v1
kind: ServiceAccount
metadata:
  name: {{ resource_name }}
  namespace: {{ namespace }}
  annotations:
    # Substituted by the deploy workflow with the terraform output
    # `iam_role_arn` from terraform/outputs.tf (IRSA role created by the
    # infra pipeline). See templates/github-workflows/deploy.yml.j2.
    eks.amazonaws.com/role-arn: "{{ irsa_role_arn_placeholder }}"
