# Shared secret Jira Automation must send as the X-Webhook-Secret header
WEBHOOK_SECRET=change-me

AWS_REGION=us-east-1
# {environment} is replaced with dev / staging / prod
SECRET_NAME_TEMPLATE=devops-agent/{environment}

# Base branch PRs target (usually main)
GITHUB_BASE_BRANCH=main
# Comma-separated GitHub usernames to auto-request as human reviewers (optional)
PR_REVIEWERS=

CLAUDE_CLI_PATH=claude
CLAUDE_PERMISSION_MODE=acceptEdits
CLAUDE_REVIEW_MAX_ITERATIONS=2

WORKDIR=./_work
